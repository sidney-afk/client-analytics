    "Export n8n Workflows": { "main": [[{ "node": "Build Workflows JSON", "type": "main", "index": 0 }]] },
    "Build Workflows JSON": { "main": [[{ "node": "Upload Workflows JSON", "type": "main", "index": 0 }]] },
    "Dump calendar_posts": { "main": [[{ "node": "Dump content_samples", "type": "main", "index": 0 }]] },
    "Dump content_samples": { "main": [[{ "node": "Build Supabase JSON", "type": "main", "index": 0 }]] },
    "Build Supabase JSON": { "main": [[{ "node": "Upload Supabase JSON", "type": "main", "index": 0 }]] }
  }
}
